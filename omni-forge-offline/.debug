<?xml version="1.0" encoding="UTF-8"?>
<!--
  CEP debug configuration for Omni Forge.
  Open Chrome at http://localhost:8088 while AE is running to debug the panel.
  Remove this file before producing the production .zxp.
-->
<ExtensionList>
  <Extension Id="com.nitzexvisual.omniforge.panel">
    <HostList>
      <Host Name="AEFT" Port="8088"/>
    </HostList>
  </Extension>
</ExtensionList>
